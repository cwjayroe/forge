{
  "name": "forge",
  "version": "0.1.0",
  "description": "Forge – AI coding agent orchestrator",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev:backend": "uvicorn backend.main:app --reload",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && electron-builder",
    "pack": "npm run build:frontend && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.forge.app",
    "productName": "Forge",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**",
      "frontend/dist/**",
      "backend/**",
      "requirements.txt",
      "!**/__pycache__",
      "!**/*.pyc"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    }
  }
}
